<!DOCTYPE html>

<html>

<head>

<title>

Smart Registration Portal

</title>

<link

rel="stylesheet"

href="/style.css">

</head>

<body>

<div class="container">

<h1>

User Registration Portal

</h1>

<form

action="/register"

method="POST">

<input

type="text"

name="name"

placeholder="Full Name"

required>

<input

type="email"

name="email"

placeholder="Email"

required>

<input

type="text"

name="phone"

placeholder="Phone Number"

required>

<button>

Register

</button>

</form>

<h2>

Registered Users

</h2>

<table>

<tr>

<th>Name</th>

<th>Email</th>

<th>Phone</th>

</tr>

<%

users.forEach(

user=>{

%>

<tr>

<td>

<%= user.name %>

</td>

<td>

<%= user.email %>

</td>

<td>

<%= user.phone %>

</td>

</tr>

<%

})

%>

</table>

</div>

</body>

</html>